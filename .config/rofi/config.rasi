configuration {
    display-drun: "Applications";
    display-window: "Windows";
    drun-display-format: "{icon} {name}";
    drun-match-fields: "name";
    font: "FantasqueSansMono Nerd Font 18";
    modi: "window,run,drun";
    show-icons: true;
    icon-theme: "Papirus";
    sort: true;
}

/* Dark theme. */
@import "~/.cache/wal/colors-rofi-dark"
