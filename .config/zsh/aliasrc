# aliases
alias vim="nvim"
alias todo="vim ~/todo.md"
alias fetch="fastfetch"
alias sound="pulsemixer"
alias update="sudo dnf update -y"
alias sendMedia="exec ~/Scripts/sendMediaToServer.sh"
alias removeMedia="rm -rf -y ~/Downloads/Media/ToSend/*"

# fun stuff
alias poetrade="exec /home/vacuum/Games/Awakened-PoE-Trade-3.25.102.AppImage"

# ask when deleting multiple
alias rm="rm -I"

# Basic colored ls
alias ls="ls ${colorflag} --human-readable --group-directories-first -1 --classify"

# Config editing binds
alias cfv="vim ~/.vimrc"
alias cfz="vim ~/.zshrc"
alias cft="vim ~/.tmux.conf"
alias cfa="vim ~/.config/zsh/aliasrc"
alias cfalacritty="vim ~/.config/alacritty/alacritty.toml"

# Reload shell
alias reload="exec $SHELL -l"

# suffix aliases
alias -s txt=nvim
alias -s h=nvim
alias -s cpp=nvim

# Time in terminal with tty
alias time="tty-clock -c -t"

# nnn shortcut
alias nnn="nnn -a -e -c"
alias n3="nnn -a -e -c"
alias n="nnn -aec"

# what's my local ip
alias localip="ifconfig | grep -Eo 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -Eo '([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1'"
